using System;
using System.Linq;
using System.Web.Mvc;
using ADMS_ERP.Data;
using ADMS_ERP.Models;
using ADMS_ERP.Models.ViewModels;
using ADMS_ERP.Repositories;

namespace ADMS_ERP.Controllers
{
    [Authorize]
    public class ItemsController : Controller
    {
        private readonly IItemRepository _repo;

        public ItemsController()
        {
            _repo = new ItemRepository(new ApplicationDbContext());
        }

        // GET: /Items
        public ActionResult Index(string search = "")
        {
            var items = _repo.GetAll(search);
            ViewBag.Search = search;
            return View(items);
        }

        // GET: /Items/Create
        public ActionResult Create() => View(new Item());

        // POST: /Items/Create
        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Create(Item item)
        {
            if (!ModelState.IsValid) return View(item);
            _repo.Add(item);
            _repo.Save();
            TempData["Success"] = "Item created successfully.";
            return RedirectToAction("Index");
        }

        // GET: /Items/Edit/5
        public ActionResult Edit(int id)
        {
            try { return View(_repo.GetById(id)); }
            catch { return HttpNotFound(); }
        }

        // POST: /Items/Edit/5
        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Edit(Item item)
        {
            if (!ModelState.IsValid) return View(item);
            item.UpdatedAt = DateTime.Now;
            _repo.Update(item);
            _repo.Save();
            TempData["Success"] = "Item updated successfully.";
            return RedirectToAction("Index");
        }

        // GET: /Items/Delete/5
        public ActionResult Delete(int id)
        {
            try { return View(_repo.GetById(id)); }
            catch { return HttpNotFound(); }
        }

        // POST: /Items/Delete/5
        [HttpPost, ActionName("Delete"), ValidateAntiForgeryToken]
        public ActionResult DeleteConfirmed(int id)
        {
            _repo.Delete(id);
            _repo.Save();
            TempData["Success"] = "Item deleted.";
            return RedirectToAction("Index");
        }

        // GET: /Items/Details/5
        public ActionResult Details(int id)
        {
            try { return View(_repo.GetById(id)); }
            catch { return HttpNotFound(); }
        }

        protected override void Dispose(bool disposing)
        {
            if (disposing) _repo.Dispose();
            base.Dispose(disposing);
        }
    }
}

6.2 ProcessController.cs
using System.Collections.Generic;
using System.Linq;
using System.Web.Mvc;
using ADMS_ERP.Data;
using ADMS_ERP.Models.ViewModels;
using ADMS_ERP.Repositories;
using Newtonsoft.Json;

namespace ADMS_ERP.Controllers
{
    [Authorize]
    public class ProcessController : Controller
    {
        private readonly IItemRepository _repo;

        public ProcessController()
        {
            _repo = new ItemRepository(new ApplicationDbContext());
        }

        // GET: /Process
        public ActionResult Index()
        {
            var vm = new ProcessItemViewModel {
                AvailableItems = _repo.GetAll()
                    .Where(i => i.Status != "Processed")
                    .ToList()
            };
            vm.Children.Add(new ChildItemInput()); // start with one row
            return View(vm);
        }

        // POST: /Process
        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Index(ProcessItemViewModel vm, string childrenJson)
        {
            // Deserialize children from JSON submitted by JS
            if (!string.IsNullOrEmpty(childrenJson))
            {
                vm.Children = JsonConvert.DeserializeObject<List<ChildItemInput>>(childrenJson)
                              ?? new List<ChildItemInput>();
            }

            // Re-populate dropdown
            vm.AvailableItems = _repo.GetAll()
                .Where(i => i.Status != "Processed").ToList();

            if (vm.ParentItemId == 0)
            {
                ModelState.AddModelError("ParentItemId", "Please select a parent item.");
                return View(vm);
            }
            if (!vm.Children.Any())
            {
                ModelState.AddModelError("", "Add at least one child item.");
                return View(vm);
            }

            var userId = (int)(Session["UserId"] ?? 1);
            var result = _repo.ProcessItem(
                vm.ParentItemId, userId, vm.Notes, vm.Children);

            if (!result.Success)
            {
                ModelState.AddModelError("", result.Message);
                return View(vm);
            }

            TempData["Success"] = result.Message;
            return RedirectToAction("Index", "ProcessedList");
        }

        // GET: /Process/Tree
        public ActionResult Tree()
        {
            var trees = _repo.GetAllTrees();
            return View(trees);
        }

        protected override void Dispose(bool disposing)
        {
            if (disposing) _repo.Dispose();
            base.Dispose(disposing);
        }
    }
}

6.3 AccountController.cs
using System.Linq;
using System.Security.Cryptography;
using System.Text;
using System.Web.Mvc;
using System.Web.Security;
using ADMS_ERP.Data;
using ADMS_ERP.Models.ViewModels;

namespace ADMS_ERP.Controllers
{
    public class AccountController : Controller
    {
        private readonly ApplicationDbContext _db;
        public AccountController() { _db = new ApplicationDbContext(); }

        // GET: /Account/Login
        [AllowAnonymous]
        public ActionResult Login(string returnUrl)
        {
            if (User.Identity.IsAuthenticated)
                return RedirectToAction("Index", "Dashboard");
            ViewBag.ReturnUrl = returnUrl;
            return View();
        }

        // POST: /Account/Login
        [HttpPost, AllowAnonymous, ValidateAntiForgeryToken]
        public ActionResult Login(LoginViewModel model, string returnUrl)
        {
            if (!ModelState.IsValid) return View(model);

            var hash = HashPassword(model.Password);
            var user = _db.Users.FirstOrDefault(u =>
                u.Email == model.Email && u.PasswordHash == hash && u.IsActive);

            if (user == null)
            {
                ModelState.AddModelError("", "Invalid email or password.");
                return View(model);
            }

            Session["UserId"]   = user.UserId;
            Session["UserName"] = user.FullName;
            FormsAuthentication.SetAuthCookie(user.Email, false);

            if (!string.IsNullOrEmpty(returnUrl) && Url.IsLocalUrl(returnUrl))
                return Redirect(returnUrl);
            return RedirectToAction("Index", "Dashboard");
        }

        // POST: /Account/Logout
        [HttpPost, ValidateAntiForgeryToken]
        public ActionResult Logout()
        {
            FormsAuthentication.SignOut();
            Session.Clear();
            return RedirectToAction("Login");
        }

        private static string HashPassword(string password)
        {
            using var sha = SHA256.Create();
            var bytes = sha.ComputeHash(Encoding.UTF8.GetBytes(password));
            return string.Concat(bytes.Select(b => b.ToString("x2")));
        }

        protected override void Dispose(bool disposing)
        {
            if (disposing) _db?.Dispose();
            base.Dispose(disposing);
        }
    }
}

