8. SQL Server Database Script
Save this script as ADMS_ERP_Database.sql and execute it in SQL Server Management Studio (SSMS) or Azure Data Studio. The script creates the database from scratch, including all tables, indexes, views, stored procedures, and seed data.

-- ============================================================
-- ADMS ERP System - SQL Server Database Script
-- ============================================================

USE master;
GO

IF EXISTS (SELECT name FROM sys.databases WHERE name = 'ADMS_ERP')
    DROP DATABASE ADMS_ERP;
GO

CREATE DATABASE ADMS_ERP;
GO

USE ADMS_ERP;
GO

-- ============================================================
-- TABLE: Users
-- ============================================================
CREATE TABLE Users (
    UserId      INT IDENTITY(1,1) PRIMARY KEY,
    Email       NVARCHAR(256) NOT NULL UNIQUE,
    PasswordHash NVARCHAR(512) NOT NULL,
    FullName    NVARCHAR(100) NOT NULL,
    CreatedAt   DATETIME2 DEFAULT GETDATE(),
    IsActive    BIT DEFAULT 1
);
GO

-- ============================================================
-- TABLE: Items
-- ============================================================
CREATE TABLE Items (
    ItemId      INT IDENTITY(1,1) PRIMARY KEY,
    Name        NVARCHAR(200) NOT NULL,
    Weight      DECIMAL(18,4) NOT NULL CHECK (Weight > 0),
    Status      NVARCHAR(50)  NOT NULL DEFAULT 'Unprocessed'
                CHECK (Status IN ('Unprocessed','Processed','PartiallyProcessed')),
    CreatedAt   DATETIME2     DEFAULT GETDATE(),
    UpdatedAt   DATETIME2     DEFAULT GETDATE(),
    CreatedBy   INT           REFERENCES Users(UserId)
);
GO

-- ============================================================
-- TABLE: ProcessingJobs
-- ============================================================
CREATE TABLE ProcessingJobs (
    JobId       INT IDENTITY(1,1) PRIMARY KEY,
    ParentItemId INT NOT NULL REFERENCES Items(ItemId),
    ProcessedAt DATETIME2 DEFAULT GETDATE(),
    ProcessedBy INT REFERENCES Users(UserId),
    Notes       NVARCHAR(500)
);
GO

-- ============================================================
-- TABLE: ItemHierarchy (parent-child relationship)
-- ============================================================
CREATE TABLE ItemHierarchy (
    HierarchyId INT IDENTITY(1,1) PRIMARY KEY,
    ParentItemId INT NOT NULL REFERENCES Items(ItemId),
    ChildItemId  INT NOT NULL REFERENCES Items(ItemId),
    JobId        INT NOT NULL REFERENCES ProcessingJobs(JobId),
    SortOrder    INT DEFAULT 0,
    CONSTRAINT UQ_ChildItem UNIQUE (ChildItemId)
);
GO

-- ============================================================
-- INDEXES
-- ============================================================
CREATE INDEX IX_Items_Status       ON Items(Status);
CREATE INDEX IX_Items_CreatedAt    ON Items(CreatedAt DESC);
CREATE INDEX IX_Hierarchy_Parent   ON ItemHierarchy(ParentItemId);
CREATE INDEX IX_Hierarchy_Child    ON ItemHierarchy(ChildItemId);
CREATE INDEX IX_Jobs_ParentItem    ON ProcessingJobs(ParentItemId);
GO

-- ============================================================
-- VIEW: ItemTreeView
-- ============================================================
CREATE VIEW ItemTreeView AS
SELECT
    p.ItemId        AS ParentItemId,
    p.Name          AS ParentName,
    p.Weight        AS ParentWeight,
    p.Status        AS ParentStatus,
    c.ItemId        AS ChildItemId,
    c.Name          AS ChildName,
    c.Weight        AS ChildWeight,
    c.Status        AS ChildStatus,
    h.SortOrder,
    j.ProcessedAt,
    j.JobId
FROM Items p
JOIN ItemHierarchy h ON h.ParentItemId = p.ItemId
JOIN Items c         ON c.ItemId = h.ChildItemId
JOIN ProcessingJobs j ON j.JobId = h.JobId;
GO

-- ============================================================
-- STORED PROCEDURE: ProcessItem
-- ============================================================
CREATE PROCEDURE sp_ProcessItem
    @ParentItemId  INT,
    @ProcessedBy   INT,
    @Notes         NVARCHAR(500),
    @ChildrenXml   XML   -- <Children><Child Name="X" Weight="10.5"/></Children>
AS
BEGIN
    SET NOCOUNT ON;
    BEGIN TRANSACTION;
    BEGIN TRY
        -- Validate parent exists
        IF NOT EXISTS (SELECT 1 FROM Items WHERE ItemId = @ParentItemId)
            THROW 50001, 'Parent item not found.', 1;

        -- Get parent weight
        DECLARE @ParentWeight DECIMAL(18,4);
        SELECT @ParentWeight = Weight FROM Items WHERE ItemId = @ParentItemId;

        -- Parse children from XML
        DECLARE @Children TABLE (Name NVARCHAR(200), Weight DECIMAL(18,4));
        INSERT INTO @Children
        SELECT
            c.value('@Name','NVARCHAR(200)'),
            c.value('@Weight','DECIMAL(18,4)')
        FROM @ChildrenXml.nodes('/Children/Child') AS T(c);

        -- Validate total child weight <= parent weight
        DECLARE @TotalChildWeight DECIMAL(18,4);
        SELECT @TotalChildWeight = SUM(Weight) FROM @Children;
        IF @TotalChildWeight > @ParentWeight
            THROW 50002, 'Total child weight exceeds parent weight.', 1;

        -- Create processing job
        DECLARE @JobId INT;
        INSERT INTO ProcessingJobs (ParentItemId, ProcessedBy, Notes)
        VALUES (@ParentItemId, @ProcessedBy, @Notes);
        SET @JobId = SCOPE_IDENTITY();

        -- Insert child items and hierarchy
        DECLARE @ChildItemId INT, @SortOrder INT = 0;
        DECLARE @ChildName NVARCHAR(200), @ChildWeight DECIMAL(18,4);

        DECLARE cur CURSOR FOR SELECT Name, Weight FROM @Children;
        OPEN cur;
        FETCH NEXT FROM cur INTO @ChildName, @ChildWeight;
        WHILE @@FETCH_STATUS = 0
        BEGIN
            INSERT INTO Items (Name, Weight, Status, CreatedBy)
            VALUES (@ChildName, @ChildWeight, 'Unprocessed', @ProcessedBy);
            SET @ChildItemId = SCOPE_IDENTITY();

            INSERT INTO ItemHierarchy (ParentItemId, ChildItemId, JobId, SortOrder)
            VALUES (@ParentItemId, @ChildItemId, @JobId, @SortOrder);

            SET @SortOrder += 1;
            FETCH NEXT FROM cur INTO @ChildName, @ChildWeight;
        END
        CLOSE cur; DEALLOCATE cur;

        -- Mark parent as Processed
        UPDATE Items SET Status = 'Processed', UpdatedAt = GETDATE()
        WHERE ItemId = @ParentItemId;

        COMMIT TRANSACTION;
        SELECT @JobId AS JobId, 'Success' AS Result;
    END TRY
    BEGIN CATCH
        ROLLBACK TRANSACTION;
        THROW;
    END CATCH
END;
GO

-- ============================================================
-- STORED PROCEDURE: GetItemTree (recursive CTE)
-- ============================================================
CREATE PROCEDURE sp_GetItemTree
    @RootItemId INT = NULL
AS
BEGIN
    SET NOCOUNT ON;
    WITH ItemTree AS (
        -- Anchor: root items (no parent or specific root)
        SELECT
            i.ItemId, i.Name, i.Weight, i.Status,
            CAST(NULL AS INT) AS ParentItemId,
            0 AS Level,
            CAST(i.Name AS NVARCHAR(MAX)) AS Path
        FROM Items i
        WHERE (@RootItemId IS NULL AND NOT EXISTS (
                SELECT 1 FROM ItemHierarchy WHERE ChildItemId = i.ItemId))
           OR (i.ItemId = @RootItemId)

        UNION ALL

        -- Recursive: children
        SELECT
            c.ItemId, c.Name, c.Weight, c.Status,
            h.ParentItemId,
            t.Level + 1,
            t.Path + ' > ' + c.Name
        FROM Items c
        JOIN ItemHierarchy h ON h.ChildItemId = c.ItemId
        JOIN ItemTree t       ON t.ItemId = h.ParentItemId
    )
    SELECT * FROM ItemTree ORDER BY Path;
END;
GO

