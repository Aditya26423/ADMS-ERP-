  <button type="submit" class="btn btn-primary" onclick="collectChildren()">Process</button>
}
@section Scripts {
<script>
var parentData = @Html.Raw(Json.Encode(Model.AvailableItems));
var childIdx = 0;
function addChild() {
  var row = '<div class="d-flex gap-2 mb-2" id="child'+childIdx+'">'
    + '<input class="form-control cname" placeholder="Child name"/>'
    + '<input class="form-control cweight" type="number" step="0.01" placeholder="Weight"/>'
    + '<button type="button" class="btn btn-danger" onclick="rmChild('+childIdx+')">x</button></div>';
  document.getElementById('childContainer').insertAdjacentHTML('beforeend',row);
  childIdx++;
}
function rmChild(i) { document.getElementById('child'+i).remove(); updateBar(); }
function updateBar() {
  var pid = document.getElementById('parentSelect').value;
  var parent = parentData.find(p=>p.ItemId==pid);
  if (!parent) { document.getElementById('weightBar').style.display='none'; return; }
  var used = Array.from(document.querySelectorAll('.cweight'))
              .reduce((s,e)=>s+parseFloat(e.value||0),0);
  var rem = Math.max(0, parent.Weight - used);
  document.getElementById('remaining').textContent = rem.toFixed(2);
  var pct = Math.min(100, Math.round(used/parent.Weight*100));
  document.getElementById('wFill').style.width = pct+'%';
  document.getElementById('weightBar').style.display='block';
}
document.getElementById('parentSelect').addEventListener('change', updateBar);
document.addEventListener('input', function(e){ if(e.target.classList.contains('cweight')) updateBar(); });
function collectChildren() {
  var rows = document.querySelectorAll('#childContainer > div');
  var arr = [];
  rows.forEach(r=>{ var n=r.querySelector('.cname').value;
    var w=parseFloat(r.querySelector('.cweight').value);
    if(n&&w>0) arr.push({Name:n,Weight:w}); });
  document.getElementById('childrenJson').value = JSON.stringify(arr);
}
addChild();
</script>
}

