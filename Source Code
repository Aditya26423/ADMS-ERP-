5. Data Access Layer
5.1 ApplicationDbContext.cs
using System.Data.Entity;
using ADMS_ERP.Models;

namespace ADMS_ERP.Data
{
    public class ApplicationDbContext : DbContext
    {
        public ApplicationDbContext() : base("name=ADMS_ERP") { }

        public DbSet<Item>           Items           { get; set; }
        public DbSet<ItemHierarchy>  ItemHierarchies { get; set; }
        public DbSet<ProcessingJob>  ProcessingJobs  { get; set; }
        public DbSet<User>           Users           { get; set; }

        protected override void OnModelCreating(DbModelBuilder modelBuilder)
        {
            // Item -> ParentHierarchies
            modelBuilder.Entity<ItemHierarchy>()
                .HasRequired(h => h.ParentItem)
                .WithMany(i => i.ChildHierarchies)
                .HasForeignKey(h => h.ParentItemId)
                .WillCascadeOnDelete(false);

            // Item -> ChildHierarchies
            modelBuilder.Entity<ItemHierarchy>()
                .HasRequired(h => h.ChildItem)
                .WithMany(i => i.ParentHierarchies)
                .HasForeignKey(h => h.ChildItemId)
                .WillCascadeOnDelete(false);

            base.OnModelCreating(modelBuilder);
        }
    }
}

5.2 ItemRepository.cs
using System;
using System.Collections.Generic;
using System.Data.Entity;
using System.Linq;
using ADMS_ERP.Data;
using ADMS_ERP.Models;
using ADMS_ERP.Models.ViewModels;

namespace ADMS_ERP.Repositories
{
    public interface IItemRepository : IDisposable
    {
        IEnumerable<Item>   GetAll(string search = null);
        Item                GetById(int id);
        void                Add(Item item);
        void                Update(Item item);
        void                Delete(int id);
        void                Save();
        ProcessResult       ProcessItem(int parentId, int userId, string notes,
                                        List<ChildItemInput> children);
        ItemTreeNode        GetItemTree(int? rootId = null);
        List<ItemTreeNode>  GetAllTrees();
    }

    public class ItemRepository : IItemRepository
    {
        private readonly ApplicationDbContext _db;

        public ItemRepository(ApplicationDbContext db) => _db = db;

        public IEnumerable<Item> GetAll(string search = null)
        {
            var q = _db.Items.AsQueryable();
            if (!string.IsNullOrWhiteSpace(search))
                q = q.Where(i => i.Name.Contains(search));
            return q.OrderByDescending(i => i.CreatedAt).ToList();
        }

        public Item GetById(int id) =>
            _db.Items.Find(id) ?? throw new KeyNotFoundException($"Item {id} not found.");

        public void Add(Item item)     { _db.Items.Add(item); }
        public void Update(Item item)  { _db.Entry(item).State = EntityState.Modified; }
        public void Delete(int id)
        {
            var item = GetById(id);
            _db.Items.Remove(item);
        }
        public void Save() => _db.SaveChanges();

        public ProcessResult ProcessItem(
            int parentId, int userId, string notes, List<ChildItemInput> children)
        {
            using var tx = _db.Database.BeginTransaction();
            try
            {
                var parent = GetById(parentId);
                var totalChildWeight = children.Sum(c => c.Weight);

                if (totalChildWeight > parent.Weight)
                    return new ProcessResult {
                        Success = false,
                        Message = $"Child total ({totalChildWeight:F2} kg) exceeds parent ({parent.Weight:F2} kg)."
                    };

                // Create processing job
                var job = new ProcessingJob {
                    ParentItemId = parentId,
                    ProcessedBy  = userId,
                    Notes        = notes
                };
                _db.ProcessingJobs.Add(job);
                _db.SaveChanges();

                // Insert children + hierarchy
                for (int i = 0; i < children.Count; i++)
                {
                    var child = new Item {
                        Name      = children[i].Name,
                        Weight    = children[i].Weight,
                        Status    = "Unprocessed",
                        CreatedBy = userId
                    };
                    _db.Items.Add(child);
                    _db.SaveChanges();

                    _db.ItemHierarchies.Add(new ItemHierarchy {
                        ParentItemId = parentId,
                        ChildItemId  = child.ItemId,
                        JobId        = job.JobId,
                        SortOrder    = i
                    });
                }

                parent.Status    = "Processed";
                parent.UpdatedAt = DateTime.Now;
                _db.Entry(parent).State = EntityState.Modified;
                _db.SaveChanges();
                tx.Commit();

                return new ProcessResult { Success = true, JobId = job.JobId,
                    Message = $"Item processed successfully. {children.Count} output(s) created." };
            }
            catch (Exception ex)
            {
                tx.Rollback();
                return new ProcessResult { Success = false, Message = "Processing failed: " + ex.Message };
            }
        }

        public List<ItemTreeNode> GetAllTrees()
        {
            // Get all root items (no parent)
            var allItems = _db.Items.ToList();
            var childIds = _db.ItemHierarchies.Select(h => h.ChildItemId).ToHashSet();
            var roots = allItems.Where(i => !childIds.Contains(i.ItemId)).ToList();
            return roots.Select(r => BuildTree(r, allItems,
                _db.ItemHierarchies.ToList())).ToList();
        }

        public ItemTreeNode GetItemTree(int? rootId = null)
        {
            var allItems = _db.Items.ToList();
            var allHierarchies = _db.ItemHierarchies.OrderBy(h => h.SortOrder).ToList();
            if (rootId == null) return null;
            var root = allItems.FirstOrDefault(i => i.ItemId == rootId);
            return root == null ? null : BuildTree(root, allItems, allHierarchies);
        }

        private ItemTreeNode BuildTree(Item item, List<Item> allItems,
            List<ItemHierarchy> allHierarchies, int level = 0)
        {
            var node = new ItemTreeNode {
                ItemId = item.ItemId, Name = item.Name,
                Weight = item.Weight, Status = item.Status, Level = level
            };
            var childIds = allHierarchies
                .Where(h => h.ParentItemId == item.ItemId)
                .OrderBy(h => h.SortOrder)
                .Select(h => h.ChildItemId).ToList();

            foreach (var cid in childIds)
            {
                var child = allItems.FirstOrDefault(i => i.ItemId == cid);
                if (child != null)
                    node.Children.Add(BuildTree(child, allItems, allHierarchies, level + 1));
            }
            return node;
        }

        public void Dispose() => _db?.Dispose();
    }

    public class ProcessResult
    {
        public bool   Success { get; set; }
        public int    JobId   { get; set; }
        public string Message { get; set; }
    }
}

